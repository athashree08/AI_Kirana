# Sarvam AI API subscription key
SARVAM_API_KEY=your_sarvam_api_key_here

# Enable mock mode (true/false) to save API credit during development
MOCK_SARVAM=true

# Twilio WhatsApp credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# Set to false to send real WhatsApp messages via Twilio
MOCK_TWILIO=true

# LLM Keys for Voice Assistant Agent
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_grok_or_groq_api_key_here
